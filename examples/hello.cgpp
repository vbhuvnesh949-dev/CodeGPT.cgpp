// ============================================
//   CodeGPT++ v1.0  —  Full Feature Demo
//   Run:  python main.py examples/hello.cgpp
// ============================================

print("=== CodeGPT++ v1.0 ===")
print("")

// ──────────────────────────────────────────
// 1. VARIABLES  (let / const)
// ──────────────────────────────────────────
print("--- Variables ---")
let x = 20
let y = 10
const PI = 3.14159

print(x)
print(y)
print(PI)

// ──────────────────────────────────────────
// 2. MATH OPERATORS
// ──────────────────────────────────────────
print("")
print("--- Math ---")
print(x + y)      // 30
print(x - y)      // 10
print(x * y)      // 200
print(x / y)      // 2
print(x % 3)      // 2
print(2 ** 8)     // 256

// ──────────────────────────────────────────
// 3. STRINGS
// ──────────────────────────────────────────
print("")
print("--- Strings ---")
let name = "CodeGPT++"
let greeting = "Hello, " + name
print(greeting)
print(name.upper())
print(name.lower())
print(name.len)

// ──────────────────────────────────────────
// 4. IF / ELIF / ELSE
// ──────────────────────────────────────────
print("")
print("--- If/Else ---")
let score = 85

if score >= 90 {
    print("Grade: A")
} elif score >= 75 {
    print("Grade: B")
} elif score >= 60 {
    print("Grade: C")
} else {
    print("Grade: F")
}

// ──────────────────────────────────────────
// 5. WHILE LOOP
// ──────────────────────────────────────────
print("")
print("--- While Loop ---")
let i = 1
while i <= 5 {
    print(i)
    i = i + 1
}

// ──────────────────────────────────────────
// 6. FOR LOOP
// ──────────────────────────────────────────
print("")
print("--- For Loop ---")
for num in range(1, 6) {
    print(num)
}

// ──────────────────────────────────────────
// 7. LISTS
// ──────────────────────────────────────────
print("")
print("--- Lists ---")
let fruits = ["apple", "banana", "cherry"]
print(fruits)
print(fruits[0])
fruits.append("mango")
print(fruits)
print(fruits.len)

for fruit in fruits {
    print(fruit)
}

// ──────────────────────────────────────────
// 8. FUNCTIONS
// ──────────────────────────────────────────
print("")
print("--- Functions ---")

fun add(a, b) {
    return a + b
}

fun greet(person) {
    print("Hello, " + person + "!")
}

fun factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

fun is_even(n) {
    return n % 2 == 0
}

print(add(3, 7))
greet("Bhai")
print(factorial(5))
print(is_even(4))
print(is_even(7))

// ──────────────────────────────────────────
// 9. BREAK / CONTINUE
// ──────────────────────────────────────────
print("")
print("--- Break / Continue ---")
for n in range(1, 11) {
    if n % 2 == 0 {
        continue
    }
    if n > 7 {
        break
    }
    print(n)    // prints 1 3 5 7
}

// ──────────────────────────────────────────
// 10. NESTED FUNCTIONS & CLOSURES
// ──────────────────────────────────────────
print("")
print("--- Nested Logic ---")

fun fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

let k = 0
while k < 8 {
    print(fib(k))
    k = k + 1
}

// ──────────────────────────────────────────
// 11. TYPE CASTING
// ──────────────────────────────────────────
print("")
print("--- Type Casting ---")
let num_str = "42"
let num_int = int(num_str)
print(num_int + 8)       // 50
print(str(3.14))
print(float("2.71"))

// ──────────────────────────────────────────
// 12. BOOLEAN LOGIC
// ──────────────────────────────────────────
print("")
print("--- Boolean Logic ---")
print(true and false)
print(true or false)
print(not true)
print(5 > 3 and 10 < 20)

// ──────────────────────────────────────────
// 13. CLASSES (OOP)
// ──────────────────────────────────────────
print("")
print("--- Classes (OOP) ---")

class Animal {
    fun init(self, name, sound) {
        self.name  = name
        self.sound = sound
    }
    fun speak(self) {
        print(self.name + " says " + self.sound)
    }
}

let dog = new Animal("Dog", "Woof")
let cat = new Animal("Cat", "Meow")
dog.speak()
cat.speak()

// ──────────────────────────────────────────
// 14. BUILT-IN FUNCTIONS
// ──────────────────────────────────────────
print("")
print("--- Built-ins ---")
print(len("hello"))
print(abs(-42))
print(max(3, 7, 1, 9, 2))
print(min(3, 7, 1, 9, 2))
print(round(3.7))
print(sqrt(144))

print("")
print("=== Done! CodeGPT++ is awesome! ===")
